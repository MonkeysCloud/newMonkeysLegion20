<div class="ml-benchmarkrow-preview" style="display: flex; background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 0.5rem 0; width: 100%;">
  <div style="flex: 2; font-weight: 500; padding-right: 1rem;">{{ operation|default('Routing (100 routes)') }}</div>
  <div style="flex: 1; text-align: right; font-weight: bold; color: #a78bfa; font-family: monospace;">{{ ml_value|default('12.5') }}{{ ml_suffix|default('K') }}</div>
  <div style="flex: 1; padding-left: 2rem; color: #10b981;">{{ vs_laravel|default('5.9x') }}</div>
  <div style="flex: 1; color: #10b981;">{{ vs_symfony|default('3.2x') }}</div>
</div>

{# Package Highlight — Canvas admin preview #}
{% if variant == 'vertical' %}
  <div data-component="package_highlight" style="padding: 2rem 1.5rem; border-top: 3px solid {{ color|default('#8b5cf6') }}; display: flex; flex-direction: column; align-items: center; text-align: center; background: #1e293b; border-radius: 12px; border-left: 1px solid rgba(255,255,255,0.08); border-right: 1px solid rgba(255,255,255,0.08); border-bottom: 1px solid rgba(255,255,255,0.08);">
    <div style="font-size: 2.5rem; margin-bottom: 1rem;">{{ icon|default('📦') }}</div>
    <h3 style="font-size: 1.15rem; font-weight: 800; margin-bottom: 0.5rem; color: white;">{{ name }}</h3>
    <p style="font-size: 0.85rem; color: #9ca3af; margin: 0; line-height: 1.5;">{{ description }}</p>
  </div>
{% else %}
  <div data-component="package_highlight" style="padding: 1rem 1.25rem; display: flex; gap: 1rem; align-items: center; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px;">
    <span style="font-size: 1.5rem; flex-shrink: 0;">{{ icon|default('📦') }}</span>
    <div style="min-width: 0;">
      <span style="font-size: 0.9rem; font-weight: bold; font-family: monospace;">{{ name }}</span>
      <p style="font-size: 0.75rem; color: #9ca3af; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ description }}</p>
    </div>
  </div>
{% endif %}

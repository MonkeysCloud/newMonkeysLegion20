{# Page Hero — Canvas admin preview #}
<div data-component="page_hero" style="padding: 4rem 2rem 3rem; background: linear-gradient(180deg, #0e1117, #131620); color: white; text-align: center; border-radius: 8px; border: 1px dashed rgba(255,255,255,0.15);">
  {% if eyebrow %}
  <div style="display: flex; justify-content: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem;">
    {% for badge in eyebrow|split('·') %}
      <span style="font-size: 0.7rem; padding: 0.25rem 0.75rem; border: 1px solid rgba(139,92,246,0.3); border-radius: 20px; color: #a78bfa; font-family: monospace;">{{ badge|trim }}</span>
    {% endfor %}
  </div>
  {% endif %}
  <h1 style="font-size: 2.5rem; font-weight: 800; margin: 0 0 0.5rem; line-height: 1.15;">
    {{ title|default('Page Title') }}
    {% if title_gradient %}
      <span style="background: linear-gradient(135deg, #8b5cf6, #06b6d4); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">{{ title_gradient }}</span>
    {% endif %}
  </h1>
  <p style="color: #9ca3af; max-width: 650px; margin: 1rem auto 1.5rem; font-size: 1rem; line-height: 1.6;">{{ subtitle }}</p>
  <div style="display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap;">
    {% block actions %}{% endblock %}
  </div>
</div>

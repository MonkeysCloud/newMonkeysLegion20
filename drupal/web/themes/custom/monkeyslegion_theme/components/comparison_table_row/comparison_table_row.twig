{# Comparison Table Row — Canvas admin preview #}
<div data-component="comparison_table_row" style="display: grid; grid-template-columns: 2fr 1.5fr 1.5fr; padding: 0.75rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.8rem; color: white;">
  <span style="font-weight: 600;">{{ capability|default('Capability') }}</span>
  <span style="color: #9ca3af;">{{ value_1 }}</span>
  <span style="color: #9ca3af;">{{ value_2 }}</span>
</div>

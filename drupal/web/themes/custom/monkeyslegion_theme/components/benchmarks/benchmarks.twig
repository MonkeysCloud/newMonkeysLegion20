{# Canvas SDC: benchmarks — rendered by Next.js frontend #}
<div data-component="benchmarks" style="padding: 3rem 2rem; background: #0b0d10; color: white; text-align: center; border-radius: 8px; border: 1px dashed rgba(255,255,255,0.2);">
  <h2 style="font-size: 2.2rem; font-weight: 800; margin-bottom: 1rem;">{{ title|default('Benchmarked, not marketed.') }}</h2>
  <p style="color: #9ca3af; font-size: 1.1rem; max-width: 700px; margin: 0 auto; margin-bottom: 2rem;">
    {{ test_environment|default('All numbers produced on Apple Silicon with PHP 8.5...') }}
  </p>
  <div style="text-align: left; background: rgba(255,255,255,0.05); border-radius: 8px; padding: 1rem;">
    <div style="display: flex; font-weight: bold; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 0.5rem; margin-bottom: 1rem;">
      <div style="flex: 2">Operation</div>
      <div style="flex: 1">Ops/sec</div>
      <div style="flex: 1">vs Laravel</div>
      <div style="flex: 1">vs Symfony</div>
    </div>
    {% block rows %}
      <div style="display: flex; flex-direction: column; gap: 0.5rem; min-height: 150px; padding-bottom: 4rem;">
        {% if rows %}
          {{ rows }}
        {% else %}
          <div style="opacity: 0.5; font-size: 0.85rem; font-style: italic; text-align: center; margin-top: 2rem; width: 100%;">
            Drag benchmark_row components here...
          </div>
        {% endif %}
      </div>
    {% endblock %}
  </div>
</div>

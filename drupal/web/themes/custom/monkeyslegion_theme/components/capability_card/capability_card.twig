{# Capability Card — Canvas admin preview #}
<div data-component="capability_card" style="padding: 1.25rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; color: white;">
  <span style="font-size: 1.5rem;">{{ icon|default('🔌') }}</span>
  <h3 style="font-size: 0.85rem; font-weight: 700; margin: 0.5rem 0 0.25rem;">{{ title|default('Capability') }}</h3>
  <p style="font-size: 0.75rem; color: #9ca3af; margin: 0; line-height: 1.5;">{{ description }}</p>
</div>

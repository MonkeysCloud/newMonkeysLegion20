<div class="ml-featurecard-preview" style="flex: 1 1 calc(30% - 1rem); min-width: 200px; background: rgba(255,255,255,0.05); padding: 1.5rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 1rem; color: #fff;">
  <div style="font-size: 1.5rem; margin-bottom: 0.5rem;">⚙️ {{ icon|default('Icon') }}</div>
  <h3 style="margin-top: 0; margin-bottom: 0.5rem; font-size: 1.2rem;">{{ title|default('Feature Title') }}</h3>
  <p style="margin: 0; font-size: 0.9rem; color: #9ca3af;">{{ description|default('Feature description goes here...') }}</p>
</div>

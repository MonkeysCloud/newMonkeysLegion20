{# Layer Diagram — Canvas admin preview #}
<div data-component="layer_diagram" style="padding: 3rem 2rem; background: #131620; color: white; border-radius: 8px; border: 1px dashed rgba(255,255,255,0.15); text-align: center;">
  <h2 style="font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem;">{{ title|default('Architecture') }} <span style="background: linear-gradient(135deg, #8b5cf6, #06b6d4); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">{{ title_gradient|default('layers.') }}</span></h2>
  <p style="color: #9ca3af; margin-bottom: 2rem;">{{ subtitle }}</p>
  <div style="display: flex; flex-direction: column; gap: 0.5rem; max-width: 700px; margin: 0 auto;">
    {% block layers %}
      <div style="opacity: 0.5; font-style: italic; padding: 2rem;">Drag layer_row components here...</div>
    {% endblock %}
  </div>
</div>

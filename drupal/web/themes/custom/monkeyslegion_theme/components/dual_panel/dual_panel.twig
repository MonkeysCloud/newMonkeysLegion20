{# Dual Panel — Canvas admin preview #}
<div data-component="dual_panel" style="padding: 3rem 2rem; background: {{ background == 'alt' ? '#131620' : '#0e1117' }}; color: white; border-radius: 8px; border: 1px dashed rgba(255,255,255,0.15);">
  {% if layer_badge %}
    <span style="display: inline-block; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.7rem; font-weight: 600; font-family: monospace; background: {{ layer_color|default('#10b981') }}25; color: {{ layer_color|default('#10b981') }}; border: 1px solid {{ layer_color|default('#10b981') }}40; margin-bottom: 1rem;">{{ layer_badge }}</span>
  {% endif %}
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start;">
    <div style="min-height: 100px; background: rgba(255,255,255,0.02); border-radius: 8px; padding: 1rem; border: 1px dashed rgba(255,255,255,0.1);">
      {% block left %}
        <div style="opacity: 0.5; font-style: italic; text-align: center;">Left column content...</div>
      {% endblock %}
    </div>
    <div style="min-height: 100px; background: rgba(255,255,255,0.02); border-radius: 8px; padding: 1rem; border: 1px dashed rgba(255,255,255,0.1);">
      {% block right %}
        <div style="opacity: 0.5; font-style: italic; text-align: center;">Right column content...</div>
      {% endblock %}
    </div>
  </div>
</div>

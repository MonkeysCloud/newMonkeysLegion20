{# Canvas SDC: architecture — rendered by Next.js frontend #}
<div data-component="architecture" style="padding: 2rem; background: linear-gradient(135deg, #0b0d10 0%, #111827 100%); border-radius: 8px; border: 1px dashed rgba(255,255,255,0.2); margin: 1rem;">
  <h2 style="font-size: 2rem; font-weight: 800; color: white; text-align: center; margin: 0 0 0.5rem 0;">{{ title|default('How a request flows.') }}</h2>
  <p style="color: #9ca3af; font-size: 1rem; text-align: center; margin: 0 0 2rem 0;">{{ subtitle|default('') }}</p>
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
    <div style="background: rgba(255,255,255,0.03); border-radius: 8px; padding: 1rem; border: 1px solid rgba(255,255,255,0.08);">
      <h3 style="color: #60a5fa; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 0.5rem 0;">Request Pipeline</h3>
      <p style="color: #666; font-size: 0.75rem; font-family: monospace;">(Static data rendered by frontend)</p>
    </div>
    <div style="background: rgba(255,255,255,0.03); border-radius: 8px; padding: 1rem; border: 1px solid rgba(255,255,255,0.08);">
      <h3 style="color: #34d399; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 0.5rem 0;">Boot Sequence</h3>
      <p style="color: #666; font-size: 0.75rem; font-family: monospace;">(Static data rendered by frontend)</p>
    </div>
  </div>
</div>

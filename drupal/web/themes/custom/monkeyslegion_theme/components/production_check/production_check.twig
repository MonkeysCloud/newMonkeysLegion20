{# Canvas SDC: production_check — rendered by Next.js frontend #}
<div data-component="production_check" style="background: #1e1e2e; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.08);">
  <div style="background: rgba(255,255,255,0.06); padding: 0.5rem 1rem; font-size: 0.75rem; font-weight: 600; color: #9ca3af; border-bottom: 1px solid rgba(255,255,255,0.08);">{{ header|default('php.ini + deploy') }}</div>
  <pre style="padding: 1rem; margin: 0; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #10b981; line-height: 1.6; white-space: pre-wrap;">{{ code|default('# Configuration code here') }}</pre>
</div>

{# Capability Grid — Canvas admin preview #}
<div data-component="capability_grid" style="padding: 3rem 2rem; background: #0e1117; color: white; border-radius: 8px; border: 1px dashed rgba(255,255,255,0.15);">
  <h2 style="font-size: 2rem; font-weight: 800; text-align: center; margin-bottom: 0.5rem;">
    {{ title|default('Fifteen capabilities.') }}
    <span style="background: linear-gradient(135deg, #8b5cf6, #06b6d4); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">{{ title_gradient|default('One package.') }}</span>
  </h2>
  <p style="text-align: center; color: #9ca3af; margin-bottom: 2rem;">{{ subtitle }}</p>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem;">
    {% block cards %}
      <div style="opacity: 0.5; font-style: italic; text-align: center; grid-column: 1/-1; padding: 2rem;">Drag capability_card components here...</div>
    {% endblock %}
  </div>
</div>

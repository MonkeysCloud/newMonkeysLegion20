{# Canvas SDC: community — rendered by Next.js frontend #}
<div data-component="community" style="padding: 3rem 2rem; background: linear-gradient(180deg, #0b0d10, hsl(250, 30%, 10%)); color: white; border-radius: 8px; border: 1px dashed rgba(255,255,255,0.2); text-align: center;">
  <h2 style="font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem;">{{ title|default('Join the') }} <span style="background: linear-gradient(135deg, #8b5cf6, #06b6d4); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">{{ title_gradient|default('build.') }}</span></h2>
  <p style="color: #9ca3af; font-size: 1.1rem; max-width: 700px; margin: 0 auto 2rem auto;">{{ subtitle|default('MonkeysLegion is MIT-licensed and actively developed in the open.') }}</p>

  {# Links #}
  <div style="text-align: left; margin-bottom: 2rem;">
    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
      <span style="background: #3b82f6; color: white; font-size: 0.7rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 4px; text-transform: uppercase;">Links</span>
      <span style="color: #6b7280; font-size: 0.75rem;">Drag Community Link here</span>
    </div>
    {% block links %}
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; min-height: 50px; padding: 0.75rem; background: rgba(255,255,255,0.02); border: 2px dashed rgba(59,130,246,0.3); border-radius: 8px;">
        {% if links %}
          {{ links }}
        {% else %}
          <div style="width: 100%; display: flex; align-items: center; justify-content: center; color: #4b5563; font-size: 0.85rem; font-style: italic;">
            ＋ Drop Community Link here…
          </div>
        {% endif %}
      </div>
    {% endblock %}
  </div>

  {# Terminal + CTA #}
  <h3 style="font-size: 1.5rem; font-weight: 800; margin-bottom: 1rem;">{{ cta_heading|default('Ready to ship?') }}</h3>
  <div style="max-width: 650px; margin: 0 auto 1.5rem auto; background: #1e1e2e; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.08);">
    <div style="display: flex; gap: 5px; padding: 0.5rem 0.75rem; background: rgba(255,255,255,0.04);">
      <span style="width: 10px; height: 10px; border-radius: 50%; background: #ff5f57;"></span>
      <span style="width: 10px; height: 10px; border-radius: 50%; background: #febc2e;"></span>
      <span style="width: 10px; height: 10px; border-radius: 50%; background: #28c840;"></span>
    </div>
    <div style="padding: 0.75rem 1rem; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem;">
      <span style="color: #10b981;">$</span> <span style="color: #d1d5db;">{{ terminal_command|default('composer create-project monkeyscloud/monkeyslegion-skeleton my-app') }}</span>
    </div>
  </div>

  <div style="text-align: left;">
    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
      <span style="background: #10b981; color: white; font-size: 0.7rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 4px; text-transform: uppercase;">Buttons</span>
      <span style="color: #6b7280; font-size: 0.75rem;">Drag CTA Button here</span>
    </div>
    {% block buttons %}
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; min-height: 50px; padding: 0.75rem; background: rgba(255,255,255,0.02); border: 2px dashed rgba(16,185,129,0.3); border-radius: 8px; justify-content: center;">
        {% if buttons %}
          {{ buttons }}
        {% else %}
          <div style="width: 100%; display: flex; align-items: center; justify-content: center; color: #4b5563; font-size: 0.85rem; font-style: italic;">
            ＋ Drop CTA Button here…
          </div>
        {% endif %}
      </div>
    {% endblock %}
  </div>
</div>

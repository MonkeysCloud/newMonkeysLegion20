{# Layer Row — Canvas admin preview #}
<div data-component="layer_row" style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1.25rem; background: rgba(255,255,255,0.03); border-left: 3px solid {{ color|default('#8b5cf6') }}; border-radius: 6px; color: white;">
  <span style="font-size: 0.85rem; font-weight: 600;">{{ label|default('Layer') }}</span>
  <span style="font-size: 0.75rem; color: {{ color|default('#8b5cf6') }};">{{ detail }}</span>
</div>

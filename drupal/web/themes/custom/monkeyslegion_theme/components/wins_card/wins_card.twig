{# Wins Card — Canvas admin preview #}
<div data-component="wins_card" style="padding: 1.25rem 1.5rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-left: 3px solid {{ accent_color|default('#ff4444') }}; border-radius: 12px; color: white;">
  <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
    <span style="font-size: 1.2rem;">{{ icon|default('📦') }}</span>
    <h3 style="font-size: 0.85rem; font-weight: 700; margin: 0;">{{ title|default('Advantage') }}</h3>
  </div>
  <p style="font-size: 0.75rem; color: #9ca3af; margin: 0; line-height: 1.5;">{{ description }}</p>
</div>

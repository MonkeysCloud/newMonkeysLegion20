{# Feature Deep Card — Canvas admin preview + Drupal rendering #}
<div data-component="feature_deep_card" style="
  padding: 1.5rem;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.06), rgba(139, 92, 246, 0.02));
  border: 1px solid rgba(139, 92, 246, 0.15);
  border-radius: 16px;
  color: #e2e8f0;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
">
  {# ─── Header: icon + title | version tag ─── #}
  <div style="display: flex; align-items: center; justify-content: space-between;">
    <div style="display: flex; align-items: center; gap: 0.5rem;">
      <span style="font-size: 1.3rem;">{{ icon|default('🧭') }}</span>
      <h3 style="font-size: 0.95rem; font-weight: 700; margin: 0; color: #f1f5f9;">{{ title|default('Feature') }}</h3>
    </div>
    {% if tag %}
      <span style="
        font-size: 0.65rem;
        font-family: 'SF Mono', 'Fira Code', monospace;
        color: #94a3b8;
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
        background: rgba(139, 92, 246, 0.1);
        border: 1px solid rgba(139, 92, 246, 0.15);
        white-space: nowrap;
      ">{{ tag }}</span>
    {% endif %}
  </div>

  {# ─── Description ─── #}
  {% if description %}
    <p style="
      font-size: 0.8rem;
      color: #94a3b8;
      margin: 0;
      line-height: 1.6;
    ">{{ description }}</p>
  {% endif %}

  {# ─── Code block ─── #}
  {% if code %}
    <div style="
      flex: 1 1 auto;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
    ">
      <pre style="
        margin: 0;
        padding: 1rem;
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(139, 92, 246, 0.1);
        border-radius: 10px;
        font-size: 0.7rem;
        line-height: 1.6;
        color: #c4b5fd;
        overflow-x: auto;
        font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
        white-space: pre-wrap;
        word-break: break-word;
      "><code>{{ code }}</code></pre>
    </div>
  {% endif %}
</div>

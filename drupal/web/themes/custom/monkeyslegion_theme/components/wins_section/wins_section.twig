{# Wins Section — Canvas admin preview #}
<div data-component="wins_section" style="padding: 3rem 2rem; background: {{ background == 'alt' ? '#131620' : '#0e1117' }}; color: white; border-radius: 8px; border: 1px dashed rgba(255,255,255,0.15);">
  <h2 style="font-size: 2rem; font-weight: 800; text-align: center; margin-bottom: 2rem;">Where <span style="color: {{ accent_color|default('#ff4444') }};">{{ framework_name|default('Framework') }}</span> wins.</h2>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1rem;">
    {% block cards %}
      <div style="opacity: 0.5; font-style: italic; text-align: center; grid-column: 1/-1; padding: 2rem;">Drag wins_card components here...</div>
    {% endblock %}
  </div>
  {% if callout_text %}
    <div style="text-align: center; margin-top: 2rem; padding: 1.25rem; background: {{ accent_color|default('#ff4444') }}10; border-radius: 12px; border: 1px solid {{ accent_color|default('#ff4444') }}25;">
      <p style="font-weight: 700; font-size: 0.9rem; margin: 0;">{{ callout_text }}</p>
    </div>
  {% endif %}
</div>

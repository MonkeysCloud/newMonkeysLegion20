{# Package Promo Section — Canvas admin preview #}
<div data-component="package_promo_section" style="padding: 3rem 2rem; background: #0f172a; color: white; border-radius: 8px; border: 1px solid rgba(139,92,246,0.15);">
  <div style="text-align: center; margin-bottom: 2rem;">
    <h2 style="font-size: 2rem; font-weight: 800; margin-bottom: 0.75rem;">
      {{ title|default('The Package') }}
      {% if title_gradient %}<span style="background: linear-gradient(135deg, #8b5cf6, #06b6d4); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">{{ title_gradient }}</span>{% endif %}
    </h2>
    <p style="color: #9ca3af; max-width: 600px; margin: 0 auto 2rem;">{{ subtitle }}</p>
    
    {# Stats preview #}
    <div style="display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;">
      {% block stats %}{% endblock %}
    </div>
  </div>

  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem;">
    {% block highlights %}{% endblock %}
  </div>

  <div style="padding: 2rem; text-align: center; background: linear-gradient(180deg, rgba(139,92,246,0.05), rgba(6,182,212,0.05)); border: 1px solid rgba(139,92,246,0.1); border-radius: 12px;">
    <h3 style="font-size: 1.2rem; font-weight: bold; margin-bottom: 1rem;">Get everything with one command</h3>
    <div style="max-width: 500px; margin: 0 auto 1.5rem; text-align: left; background: rgba(0,0,0,0.3); border-radius: 8px; overflow: hidden;">
      <div style="padding: 0.4rem 0.75rem; display: flex; gap: 0.3rem;"><span style="width: 8px; height: 8px; border-radius: 50%; background: #ff5f57;"></span><span style="width: 8px; height: 8px; border-radius: 50%; background: #ffbd2e;"></span><span style="width: 8px; height: 8px; border-radius: 50%; background: #28ca41;"></span></div>
      <div style="padding: 0.75rem; font-family: monospace; font-size: 0.8rem; color: #e2e8f0;"><span style="color: #06b6d4;">$</span> {{ terminal_command }}</div>
    </div>
    <div style="display: flex; justify-content: center; gap: 1rem;">
      {% block actions %}{% endblock %}
    </div>
  </div>
</div>

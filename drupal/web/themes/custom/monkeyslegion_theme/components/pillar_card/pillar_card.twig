<div class="ml-pillarcard-preview" style="flex: 1 1 calc(30% - 1rem); min-width: 200px; background: rgba(255,255,255,0.05); padding: 1.5rem; text-align: center; position: relative; overflow: hidden; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 1rem; color: #fff;">
  <div style="position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 80px; height: 3px; background: linear-gradient(90deg, transparent, #818cf8, transparent); border-radius: 4px;"></div>
  <div style="font-size: 2rem; margin-bottom: 0.5rem;">{{ icon|default('🚀') }}</div>
  <h3 style="margin-top: 0; margin-bottom: 0.5rem; font-size: 1.2rem;">{{ title|default('Pillar Title') }}</h3>
  <h4 style="margin: 0; margin-bottom: 0.5rem; font-size: 0.9rem; color: #818cf8;">{{ subtitle|default('Subtitle goes here') }}</h4>
  <p style="margin: 0; font-size: 0.85rem; color: #9ca3af;">{{ description|default('Detailed explanation of this core pillar of the framework...') }}</p>
</div>

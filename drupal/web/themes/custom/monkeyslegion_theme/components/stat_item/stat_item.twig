{# Stat Item — Canvas admin preview #}
<div data-component="stat_item" style="text-align: center; background: rgba(255,255,255,0.05); padding: 0.75rem 1.5rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); min-width: 140px;">
  <div style="font-size: 1.25rem; font-weight: bold; background: linear-gradient(135deg, #8b5cf6, #06b6d4); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">{{ value }}</div>
  <div style="font-size: 0.7rem; color: #9ca3af; text-transform: uppercase;">{{ label }}</div>
</div>

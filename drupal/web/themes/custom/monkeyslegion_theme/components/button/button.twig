<a href="{{ url }}" style="display: inline-block; padding: 0.6rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 0.95rem; cursor: pointer; {% if style == 'secondary' %}background: transparent; border: 1px solid #555; color: #e5e7eb;{% else %}background: linear-gradient(135deg, #6c47ff, #a855f7); color: white; border: none;{% endif %}">{{ text }}</a>

{# Framework Trait — Canvas admin preview #}
<div data-component="framework_trait" style="display: flex; gap: 1rem; align-items: flex-start; padding: 1.25rem 1.5rem; background: #131620; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; color: white;">
  <div style="font-size: 1.8rem; flex-shrink: 0; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 8px; background: rgba(139,92,246,0.1);">
    {{ icon|default('⚡') }}
  </div>
  <div>
    <h3 style="font-size: 1rem; font-weight: 700; margin: 0 0 0.25rem 0;">{{ title|default('Trait Title') }}</h3>
    <p style="font-size: 0.875rem; color: #94a3b8; line-height: 1.6; margin: 0;">{{ description|default('Description text') }}</p>
  </div>
</div>

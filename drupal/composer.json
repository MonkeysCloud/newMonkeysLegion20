{
    "name": "monkeyscloud/monkeyslegion-v2-site",
    "description": "MonkeysLegion v2.0 info site — Drupal 11 headless CMS with Canvas",
    "type": "project",
    "license": "MIT",
    "homepage": "https://monkeyslegion.com",
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require": {
        "composer/installers": "^2.0",
        "drupal/admin_toolbar": "^3.0",
        "drupal/canvas": "^1.3",
        "drupal/core-composer-scaffold": "^11",
        "drupal/core-project-message": "^11",
        "drupal/core-recommended": "^11",
        "drupal/decoupled_router": "^2.0",
        "drupal/entity_reference_revisions": "^1.0",
        "drupal/focal_point": "^2.0",
        "drupal/gin": "^5.0",
        "drupal/gin_toolbar": "^3.0",
        "drupal/google_tag": "^2.0",
        "drupal/jsonapi_extras": "^3.0",
        "drupal/jsonapi_include": "^1.0",
        "drupal/jsonapi_search_api": "^1.0",
        "drupal/markdown": "^3.1",
        "drupal/media_entity_download": "^2.0",
        "drupal/media_library_form_element": "^2.0",
        "drupal/metatag": "^2.0",
        "drupal/next": "^2.0",
        "drupal/paragraphs": "^1.0",
        "drupal/pathauto": "^1.0",
        "drupal/redirect": "^1.0",
        "drupal/schema_metatag": "^3.0",
        "drupal/search_api": "^1.0",
        "drupal/search_api_db": "^1.0",
        "drupal/simple_oauth": "^6.0",
        "drupal/simple_sitemap": "^4.0",
        "drupal/subrequests": "^3.0",
        "drupal/token": "^1.0",
        "drush/drush": "^13",
        "league/commonmark": "^2.8"
    },
    "require-dev": {
        "drupal/core-dev": "^11"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "beta",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true
        },
        "sort-packages": true
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            }
        },
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/libraries/{$name}": ["type:drupal-library"],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/profiles/contrib/{$name}": ["type:drupal-profile"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "drush/Commands/contrib/{$name}": ["type:drupal-drush"],
            "web/modules/custom/{$name}": ["type:drupal-custom-module"],
            "web/profiles/custom/{$name}": ["type:drupal-custom-profile"],
            "web/themes/custom/{$name}": ["type:drupal-custom-theme"]
        },
        "drupal-core-project-message": {
            "include-keys": ["homepage", "support"],
            "post-create-project-cmd-message": [
                "<bg=blue;fg=white>                                                         </>",
                "<bg=blue;fg=white>  MonkeysLegion v2.0 Info Site — Drupal 11 Backend        </>",
                "<bg=blue;fg=white>                                                         </>"
            ]
        }
    }
}

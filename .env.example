# =============================================================================
# MonkeysLegion v2.0 Info Site — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- MySQL Database ---
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_DATABASE=drupal
MYSQL_USER=drupal
MYSQL_PASSWORD=drupal_password_change_me

# --- Drupal Backend ---
DRUPAL_DB_HOST=mysql
DRUPAL_DB_PORT=3306
DRUPAL_DB_NAME=drupal
DRUPAL_DB_USER=drupal
DRUPAL_DB_PASSWORD=drupal_password_change_me
DRUPAL_HASH_SALT=change-this-to-a-random-64-char-string

# --- Next.js Frontend ---
NEXT_PUBLIC_DRUPAL_BASE_URL=http://nginx
NEXT_IMAGE_DOMAIN=localhost
DRUPAL_SITE_ID=monkeyslegion_v2
DRUPAL_FRONT_PAGE=/
DRUPAL_PREVIEW_SECRET=preview-secret-change-me

# --- Simple OAuth (Drupal) ---
DRUPAL_CLIENT_ID=monkeyslegion-nextjs
DRUPAL_CLIENT_SECRET=client-secret-change-me

# --- Google Analytics ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
